# Supabase — copie para .env.local e preencha
# Local (supabase start gera estes valores):
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Nome do app (opcional)
VITE_APP_NAME=Resultadismo

# Web Push (opcional) — chave pública VAPID. Gere com: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
