# Secrets das Edge Functions (NÃO commitar valores reais).
# Em produção: supabase secrets set NOME=valor

# --- Mercado Pago (criação de ligas paga) ---
# Access Token de produção. Painel: https://www.mercadopago.com.br/developers
MERCADOPAGO_ACCESS_TOKEN=
# Segredo do webhook (opcional, recomendado): valida a assinatura x-signature do MP
MP_WEBHOOK_SECRET=
# Preço da criação de liga, em centavos de BRL (ex.: 990 = R$ 9,90)
LEAGUE_PRICE_CENTS=990
# URL pública do app (back_urls do checkout)
APP_URL=https://resultadismo.com

